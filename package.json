{
  "name": "maxima",
  "version": "0.2.0",
  "description": "Laravel-inspired Node.js framework powered by Fastify.",
  "type": "module",
  "bin": {
    "maxima": "./bin/maxima.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "test": "vitest run",
    "dev": "tsx watch --include \"src/**/*.edge\" src/server.ts",
    "maxima": "tsx lib/cli/maxima.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/csrf-protection": "^7.1.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/session": "^11.1.0",
    "@fastify/static": "^9.1.3",
    "@vinejs/vine": "^3.0.1",
    "argon2": "^0.41.1",
    "basic-ftp": "^6.0.1",
    "better-sqlite3": "^12.10.0",
    "bullmq": "^5.77.6",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "edge.js": "^6.2.1",
    "fastify": "^5.1.0",
    "knex": "^3.1.0",
    "mime-types": "^2.1.35",
    "mjml": "^5.3.0",
    "moment": "^2.30.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.10",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "redis": "^6.0.0",
    "ssh2-sftp-client": "^12.1.1",
    "ulid": "^2.3.0",
    "ws": "^8.21.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.0",
    "@types/ws": "^8.18.1",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
