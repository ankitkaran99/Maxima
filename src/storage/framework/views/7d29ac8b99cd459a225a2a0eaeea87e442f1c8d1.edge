{"source":"C:\\Users\\ankit\\Storage\\maxima\\src\\resources\\views\\home.edge","template":"home","mtimeMs":1779848902036.5022,"compiled":"<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>{{ title || 'Maxima' }}</title>\n    <style>\n      :root {\n        color-scheme: light;\n        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n        color: #18202b;\n        background: #f6f8fb;\n      }\n\n      * {\n        box-sizing: border-box;\n      }\n\n      body {\n        margin: 0;\n        min-height: 100vh;\n        background:\n          radial-gradient(circle at top left, rgba(13, 148, 136, 0.14), transparent 32rem),\n          linear-gradient(135deg, #f8fafc 0%, #eef4f7 52%, #fff7ed 100%);\n      }\n\n      .shell {\n        width: min(1120px, calc(100% - 40px));\n        min-height: 100vh;\n        margin: 0 auto;\n        display: grid;\n        align-content: center;\n        gap: 32px;\n        padding: 44px 0;\n      }\n\n      .nav {\n        display: flex;\n        align-items: center;\n        justify-content: space-between;\n        gap: 20px;\n      }\n\n      .brand {\n        display: inline-flex;\n        align-items: center;\n        gap: 12px;\n        color: #111827;\n        font-weight: 800;\n        font-size: 20px;\n      }\n\n      .brand img {\n        width: 44px;\n        height: 44px;\n        object-fit: contain;\n      }\n\n      .nav a {\n        color: #0f766e;\n        font-weight: 700;\n        text-decoration: none;\n      }\n\n      .hero {\n        display: grid;\n        grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.95fr);\n        gap: 48px;\n        align-items: center;\n      }\n\n      h1 {\n        margin: 0;\n        max-width: 740px;\n        color: #111827;\n        font-size: clamp(48px, 7vw, 92px);\n        line-height: 0.94;\n        letter-spacing: 0;\n      }\n\n      .lead {\n        max-width: 620px;\n        margin: 24px 0 0;\n        color: #475569;\n        font-size: 20px;\n        line-height: 1.6;\n      }\n\n      .actions {\n        display: flex;\n        flex-wrap: wrap;\n        gap: 12px;\n        margin-top: 32px;\n      }\n\n      .button {\n        display: inline-flex;\n        align-items: center;\n        justify-content: center;\n        min-height: 46px;\n        padding: 0 18px;\n        border-radius: 8px;\n        border: 1px solid #cbd5e1;\n        color: #0f172a;\n        background: rgba(255, 255, 255, 0.72);\n        font-weight: 800;\n        text-decoration: none;\n      }\n\n      .button.primary {\n        border-color: #0f766e;\n        color: #ffffff;\n        background: #0f766e;\n      }\n\n      .logo-panel {\n        display: grid;\n        place-items: center;\n        min-height: 360px;\n        border: 1px solid rgba(15, 23, 42, 0.08);\n        border-radius: 8px;\n        background: rgba(255, 255, 255, 0.72);\n        box-shadow: 0 24px 80px rgba(15, 23, 42, 0.12);\n      }\n\n      .logo-panel img {\n        width: min(78%, 420px);\n        height: auto;\n        object-fit: contain;\n      }\n\n      .stats {\n        display: grid;\n        grid-template-columns: repeat(3, minmax(0, 1fr));\n        gap: 1px;\n        overflow: hidden;\n        border: 1px solid rgba(15, 23, 42, 0.08);\n        border-radius: 8px;\n        background: rgba(15, 23, 42, 0.08);\n      }\n\n      .stat {\n        padding: 18px;\n        background: rgba(255, 255, 255, 0.74);\n      }\n\n      .stat strong {\n        display: block;\n        color: #111827;\n        font-size: 18px;\n      }\n\n      .stat span {\n        display: block;\n        margin-top: 6px;\n        color: #64748b;\n        line-height: 1.4;\n      }\n\n      @media (max-width: 760px) {\n        .shell {\n          width: min(100% - 28px, 560px);\n          padding: 28px 0;\n        }\n\n        .nav {\n          align-items: flex-start;\n        }\n\n        .hero {\n          grid-template-columns: 1fr;\n          gap: 28px;\n        }\n\n        h1 {\n          font-size: 48px;\n        }\n\n        .lead {\n          font-size: 18px;\n        }\n\n        .logo-panel {\n          min-height: 260px;\n        }\n\n        .stats {\n          grid-template-columns: 1fr;\n        }\n      }\n    </style>\n  </head>\n  <body>\n    <main class=\"shell\">\n      <header class=\"nav\" aria-label=\"Primary\">\n        <div class=\"brand\">\n          <img src=\"/assets/maxima.png\" alt=\"Maxima logo\">\n          <span>{{ title || 'Maxima' }}</span>\n        </div>\n        <a href=\"/api/health\">API health</a>\n      </header>\n\n      <section class=\"hero\">\n        <div>\n          <h1>Laravel-style velocity for TypeScript services.</h1>\n          <p class=\"lead\">Maxima pairs Fastify performance with a full-stack developer experience: routing, middleware, validation, ORM tools, queues, mail, notifications, storage, events, scheduling, and testing helpers.</p>\n        </div>\n\n        <div class=\"logo-panel\" aria-label=\"Maxima brand mark\">\n          <img src=\"/assets/maxima.png\" alt=\"Maxima logo\">\n        </div>\n      </section>\n\n      <section class=\"stats\" aria-label=\"Framework highlights\">\n        <div class=\"stat\">\n          <strong>Fastify core</strong>\n          <span>Lean HTTP runtime with expressive framework conventions.</span>\n        </div>\n        <div class=\"stat\">\n          <strong>Full app stack</strong>\n          <span>Database, queues, mail, notifications, storage, and events.</span>\n        </div>\n        <div class=\"stat\">\n          <strong>Testable by default</strong>\n          <span>Fakes, assertions, snapshots, and console testing included.</span>\n        </div>\n      </section>\n    </main>\n  </body>\n</html>\n"}