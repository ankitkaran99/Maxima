{"source":"C:\\Users\\ankit\\Storage\\maxima\\src\\resources\\views\\errors\\404.edge","template":"errors/404","mtimeMs":1779817806064.9973,"compiled":"<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>Not Found</title>\n    <style>\n      body {\n        margin: 0;\n        min-height: 100vh;\n        display: grid;\n        place-items: center;\n        padding: 24px;\n        color: #18202b;\n        background: linear-gradient(135deg, #f8fafc, #eef6f6);\n        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n      }\n\n      main {\n        width: min(100%, 680px);\n        border: 1px solid #dbe7e7;\n        border-radius: 8px;\n        background: #ffffff;\n        padding: 36px;\n        box-shadow: 0 18px 60px rgba(15, 23, 42, 0.09);\n      }\n\n      img {\n        width: 56px;\n        height: 56px;\n        object-fit: contain;\n      }\n\n      .code {\n        margin: 22px 0 8px;\n        color: #0f766e;\n        font-weight: 800;\n        text-transform: uppercase;\n      }\n\n      h1 {\n        margin: 0;\n        font-size: 40px;\n        line-height: 1.1;\n        letter-spacing: 0;\n      }\n\n      p {\n        margin: 14px 0 0;\n        color: #64748b;\n        font-size: 18px;\n        line-height: 1.6;\n      }\n\n      a {\n        display: inline-flex;\n        margin-top: 26px;\n        color: #0f766e;\n        font-weight: 800;\n        text-decoration: none;\n      }\n    </style>\n  </head>\n  <body>\n    <main>\n      <img src=\"/assets/maxima.png\" alt=\"Maxima logo\">\n      <div class=\"code\">404</div>\n      <h1>Not Found</h1>\n      <p>{{ message }}</p>\n      <a href=\"/\">Return home</a>\n    </main>\n  </body>\n</html>\n"}