<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ errorName }} - {{ message }}</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f3f4f6;
        --panel: #ffffff;
        --panel-soft: #f8fafc;
        --border: #d1d5db;
        --text: #0f172a;
        --muted: #475569;
        --accent: #b91c1c;
        --code-bg: #111827;
        --code-text: #e5e7eb;
        --code-highlight: #1f2937;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at top, rgba(185, 28, 28, 0.08), transparent 28%),
          linear-gradient(180deg, #ffffff 0%, var(--bg) 100%);
        color: var(--text);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      .shell {
        width: min(1200px, calc(100% - 32px));
        margin: 0 auto;
        padding: 24px 0 40px;
      }

      .header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        padding: 20px 0 18px;
      }

      .brand {
        display: grid;
        gap: 8px;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--accent);
        font-size: 13px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .eyebrow::before {
        content: '';
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: var(--accent);
        box-shadow: 0 0 0 6px rgba(185, 28, 28, 0.08);
      }

      h1 {
        margin: 0;
        font-size: 34px;
        line-height: 1.12;
        letter-spacing: 0;
      }

      .message {
        margin: 0;
        color: var(--muted);
        font-size: 16px;
        line-height: 1.6;
        max-width: 70ch;
      }

      .meta-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
        margin-top: 18px;
      }

      .meta {
        border: 1px solid var(--border);
        border-radius: 10px;
        background: var(--panel);
        padding: 14px;
      }

      .meta span {
        display: block;
      }

      .meta .label {
        color: var(--muted);
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .meta .value {
        margin-top: 6px;
        font-size: 14px;
        line-height: 1.45;
        word-break: break-word;
      }

      .layout {
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
        gap: 18px;
        margin-top: 18px;
      }

      .panel {
        border: 1px solid var(--border);
        border-radius: 12px;
        background: var(--panel);
        overflow: hidden;
      }

      .panel-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 14px 16px;
        border-bottom: 1px solid var(--border);
        background: var(--panel-soft);
      }

      .panel-title {
        margin: 0;
        font-size: 14px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .code-frame {
        background: var(--code-bg);
        color: var(--code-text);
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
        font-size: 13px;
        line-height: 1.7;
        overflow-x: auto;
      }

      .code-line {
        display: grid;
        grid-template-columns: 72px minmax(0, 1fr);
        gap: 12px;
        padding: 0 16px;
      }

      .code-line + .code-line {
        border-top: 1px solid rgba(255, 255, 255, 0.05);
      }

      .code-line.highlight {
        background: var(--code-highlight);
      }

      .line-number {
        color: #9ca3af;
        text-align: right;
        user-select: none;
      }

      .line-content {
        white-space: pre-wrap;
        word-break: break-word;
      }

      .trace-list {
        display: grid;
      }

      .trace-item {
        padding: 14px 16px;
        border-top: 1px solid var(--border);
      }

      .trace-item:first-child {
        border-top: 0;
      }

      .trace-method {
        margin: 0 0 6px;
        font-size: 14px;
        font-weight: 700;
      }

      .trace-path {
        margin: 0;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.5;
        word-break: break-word;
      }

      details {
        margin-top: 18px;
        border: 1px solid var(--border);
        border-radius: 12px;
        background: var(--panel);
        overflow: hidden;
      }

      summary {
        cursor: pointer;
        list-style: none;
        padding: 14px 16px;
        font-weight: 800;
        background: var(--panel-soft);
      }

      summary::-webkit-details-marker {
        display: none;
      }

      pre {
        margin: 0;
        padding: 16px;
        overflow: auto;
        background: #0f172a;
        color: #e2e8f0;
        font-size: 13px;
        line-height: 1.7;
        white-space: pre-wrap;
        word-break: break-word;
      }

      .footer {
        margin-top: 18px;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.5;
      }

      @media (max-width: 980px) {
        .layout,
        .meta-grid {
          grid-template-columns: 1fr;
        }

        .header {
          flex-direction: column;
        }
      }
    </style>
  </head>
  <body>
    <main class="shell">
      <section class="header">
        <div class="brand">
          <div class="eyebrow">Application Error</div>
          <h1>{{ errorName }}: {{ message }}</h1>
          <p class="message">The application hit an exception while rendering this request. The snippet below shows the active frame and the stack trace collected from the failing request.</p>
        </div>
      </section>

      <section class="meta-grid" aria-label="Request summary">
        <div class="meta">
          <span class="label">Status</span>
          <span class="value">{{ statusCode }}</span>
        </div>
        <div class="meta">
          <span class="label">Request</span>
          <span class="value">{{ req.method }} {{ req.url }}</span>
        </div>
        <div class="meta">
          <span class="label">Route</span>
          <span class="value">{{ req.route }}</span>
        </div>
        <div class="meta">
          <span class="label">Environment</span>
          <span class="value">{{ app.env }}{{ app.debug ? ' (debug)' : '' }}</span>
        </div>
      </section>

      <section class="layout">
        <article class="panel">
          <div class="panel-head">
            <h2 class="panel-title">Source</h2>
            <span>{{ sourceFile }}</span>
          </div>
          <div class="panel-body">
            @if(sourceHtml)
              <div class="code-frame" aria-label="Source excerpt">
                {{{ sourceHtml }}} 
              </div>
            @else
              <div style="padding: 16px; color: #475569;">No local source file could be resolved for the top stack frame.</div>
            @endif
          </div>
        </article>

        <aside class="panel">
          <div class="panel-head">
            <h2 class="panel-title">Trace</h2>
            <span>{{ traceCount }} frames</span>
          </div>
          <div class="trace-list">
            {{{ traceHtml }}}
          </div>
        </aside>
      </section>

      <details>
        <summary>Stack trace</summary>
        <pre>{{ stack }}</pre>
      </details>

      <p class="footer">Request IP: {{ req.ip }} &middot; App: {{ app.name }}</p>
    </main>
  </body>
</html>
