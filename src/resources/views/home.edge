<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title || 'Maxima' }}</title>
    <style>
      :root {
        color-scheme: light;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: #18202b;
        background: #f6f8fb;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at top left, rgba(13, 148, 136, 0.14), transparent 32rem),
          linear-gradient(135deg, #f8fafc 0%, #eef4f7 52%, #fff7ed 100%);
      }

      .shell {
        width: min(1120px, calc(100% - 40px));
        min-height: 100vh;
        margin: 0 auto;
        display: grid;
        align-content: center;
        gap: 32px;
        padding: 44px 0;
      }

      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        color: #111827;
        font-weight: 800;
        font-size: 20px;
      }

      .brand img {
        width: 44px;
        height: 44px;
        object-fit: contain;
      }

      .nav a {
        color: #0f766e;
        font-weight: 700;
        text-decoration: none;
      }

      .hero {
        display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.95fr);
        gap: 48px;
        align-items: center;
      }

      h1 {
        margin: 0;
        max-width: 740px;
        color: #111827;
        font-size: clamp(48px, 7vw, 92px);
        line-height: 0.94;
        letter-spacing: 0;
      }

      .lead {
        max-width: 620px;
        margin: 24px 0 0;
        color: #475569;
        font-size: 20px;
        line-height: 1.6;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 32px;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 46px;
        padding: 0 18px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        color: #0f172a;
        background: rgba(255, 255, 255, 0.72);
        font-weight: 800;
        text-decoration: none;
      }

      .button.primary {
        border-color: #0f766e;
        color: #ffffff;
        background: #0f766e;
      }

      .logo-panel {
        display: grid;
        place-items: center;
        min-height: 360px;
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.72);
        box-shadow: 0 24px 80px rgba(15, 23, 42, 0.12);
      }

      .logo-panel img {
        width: min(78%, 420px);
        height: auto;
        object-fit: contain;
      }

      .stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1px;
        overflow: hidden;
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 8px;
        background: rgba(15, 23, 42, 0.08);
      }

      .stat {
        padding: 18px;
        background: rgba(255, 255, 255, 0.74);
      }

      .stat strong {
        display: block;
        color: #111827;
        font-size: 18px;
      }

      .stat span {
        display: block;
        margin-top: 6px;
        color: #64748b;
        line-height: 1.4;
      }

      @media (max-width: 760px) {
        .shell {
          width: min(100% - 28px, 560px);
          padding: 28px 0;
        }

        .nav {
          align-items: flex-start;
        }

        .hero {
          grid-template-columns: 1fr;
          gap: 28px;
        }

        h1 {
          font-size: 48px;
        }

        .lead {
          font-size: 18px;
        }

        .logo-panel {
          min-height: 260px;
        }

        .stats {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <main class="shell">
      <header class="nav" aria-label="Primary">
        <div class="brand">
          <img src="/assets/maxima.png" alt="Maxima logo">
          <span>{{ title || 'Maxima' }}</span>
        </div>
        <a href="/api/health">API health</a>
      </header>

      <section class="hero">
        <div>
          <h1>Laravel-style velocity for TypeScript services.</h1>
          <p class="lead">Maxima pairs Fastify performance with a full-stack developer experience: routing, middleware, validation, ORM tools, queues, mail, notifications, storage, events, scheduling, and testing helpers.</p>
          <div class="actions" aria-label="Common actions">
            <a class="button primary" href="/api/health">Check API</a>
            <a class="button" href="/assets/maxima.png">View logo</a>
          </div>
        </div>

        <div class="logo-panel" aria-label="Maxima brand mark">
          <img src="/assets/maxima.png" alt="Maxima logo">
        </div>
      </section>

      <section class="stats" aria-label="Framework highlights">
        <div class="stat">
          <strong>Fastify core</strong>
          <span>Lean HTTP runtime with expressive framework conventions.</span>
        </div>
        <div class="stat">
          <strong>Full app stack</strong>
          <span>Database, queues, mail, notifications, storage, and events.</span>
        </div>
        <div class="stat">
          <strong>Testable by default</strong>
          <span>Fakes, assertions, snapshots, and console testing included.</span>
        </div>
      </section>
    </main>
  </body>
</html>
