{"source":"C:\\Users\\ankit\\Storage\\maxima\\src\\resources\\views\\errors\\debug.edge","template":"errors/debug","mtimeMs":1779937388060.33,"compiled":"<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>{{ errorName }} - {{ message }}</title>\n    <style>\n      :root {\n        color-scheme: light;\n        --bg: #f3f4f6;\n        --panel: #ffffff;\n        --panel-soft: #f8fafc;\n        --border: #d1d5db;\n        --text: #0f172a;\n        --muted: #475569;\n        --accent: #b91c1c;\n        --code-bg: #111827;\n        --code-text: #e5e7eb;\n        --code-highlight: #1f2937;\n      }\n\n      * { box-sizing: border-box; }\n\n      body {\n        margin: 0;\n        min-height: 100vh;\n        background:\n          radial-gradient(circle at top, rgba(185, 28, 28, 0.08), transparent 28%),\n          linear-gradient(180deg, #ffffff 0%, var(--bg) 100%);\n        color: var(--text);\n        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n      }\n\n      .shell {\n        width: min(1200px, calc(100% - 32px));\n        margin: 0 auto;\n        padding: 24px 0 40px;\n      }\n\n      .header {\n        display: flex;\n        align-items: flex-start;\n        justify-content: space-between;\n        gap: 16px;\n        padding: 20px 0 18px;\n      }\n\n      .brand {\n        display: grid;\n        gap: 8px;\n      }\n\n      .eyebrow {\n        display: inline-flex;\n        align-items: center;\n        gap: 8px;\n        color: var(--accent);\n        font-size: 13px;\n        font-weight: 800;\n        text-transform: uppercase;\n        letter-spacing: 0.08em;\n      }\n\n      .eyebrow::before {\n        content: '';\n        width: 10px;\n        height: 10px;\n        border-radius: 999px;\n        background: var(--accent);\n        box-shadow: 0 0 0 6px rgba(185, 28, 28, 0.08);\n      }\n\n      h1 {\n        margin: 0;\n        font-size: 34px;\n        line-height: 1.12;\n        letter-spacing: 0;\n      }\n\n      .message {\n        margin: 0;\n        color: var(--muted);\n        font-size: 16px;\n        line-height: 1.6;\n        max-width: 70ch;\n      }\n\n      .meta-grid {\n        display: grid;\n        grid-template-columns: repeat(4, minmax(0, 1fr));\n        gap: 12px;\n        margin-top: 18px;\n      }\n\n      .meta {\n        border: 1px solid var(--border);\n        border-radius: 10px;\n        background: var(--panel);\n        padding: 14px;\n      }\n\n      .meta span {\n        display: block;\n      }\n\n      .meta .label {\n        color: var(--muted);\n        font-size: 12px;\n        font-weight: 700;\n        text-transform: uppercase;\n        letter-spacing: 0.08em;\n      }\n\n      .meta .value {\n        margin-top: 6px;\n        font-size: 14px;\n        line-height: 1.45;\n        word-break: break-word;\n      }\n\n      .layout {\n        display: grid;\n        grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);\n        gap: 18px;\n        margin-top: 18px;\n      }\n\n      .panel {\n        border: 1px solid var(--border);\n        border-radius: 12px;\n        background: var(--panel);\n        overflow: hidden;\n      }\n\n      .panel-head {\n        display: flex;\n        align-items: center;\n        justify-content: space-between;\n        gap: 12px;\n        padding: 14px 16px;\n        border-bottom: 1px solid var(--border);\n        background: var(--panel-soft);\n      }\n\n      .panel-title {\n        margin: 0;\n        font-size: 14px;\n        font-weight: 800;\n        text-transform: uppercase;\n        letter-spacing: 0.08em;\n      }\n\n      .code-frame {\n        background: var(--code-bg);\n        color: var(--code-text);\n        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", monospace;\n        font-size: 13px;\n        line-height: 1.7;\n        overflow-x: auto;\n      }\n\n      .code-line {\n        display: grid;\n        grid-template-columns: 72px minmax(0, 1fr);\n        gap: 12px;\n        padding: 0 16px;\n      }\n\n      .code-line + .code-line {\n        border-top: 1px solid rgba(255, 255, 255, 0.05);\n      }\n\n      .code-line.highlight {\n        background: var(--code-highlight);\n      }\n\n      .line-number {\n        color: #9ca3af;\n        text-align: right;\n        user-select: none;\n      }\n\n      .line-content {\n        white-space: pre-wrap;\n        word-break: break-word;\n      }\n\n      .trace-list {\n        display: grid;\n      }\n\n      .trace-item {\n        padding: 14px 16px;\n        border-top: 1px solid var(--border);\n      }\n\n      .trace-item:first-child {\n        border-top: 0;\n      }\n\n      .trace-method {\n        margin: 0 0 6px;\n        font-size: 14px;\n        font-weight: 700;\n      }\n\n      .trace-path {\n        margin: 0;\n        color: var(--muted);\n        font-size: 13px;\n        line-height: 1.5;\n        word-break: break-word;\n      }\n\n      details {\n        margin-top: 18px;\n        border: 1px solid var(--border);\n        border-radius: 12px;\n        background: var(--panel);\n        overflow: hidden;\n      }\n\n      summary {\n        cursor: pointer;\n        list-style: none;\n        padding: 14px 16px;\n        font-weight: 800;\n        background: var(--panel-soft);\n      }\n\n      summary::-webkit-details-marker {\n        display: none;\n      }\n\n      pre {\n        margin: 0;\n        padding: 16px;\n        overflow: auto;\n        background: #0f172a;\n        color: #e2e8f0;\n        font-size: 13px;\n        line-height: 1.7;\n        white-space: pre-wrap;\n        word-break: break-word;\n      }\n\n      .footer {\n        margin-top: 18px;\n        color: var(--muted);\n        font-size: 13px;\n        line-height: 1.5;\n      }\n\n      @media (max-width: 980px) {\n        .layout,\n        .meta-grid {\n          grid-template-columns: 1fr;\n        }\n\n        .header {\n          flex-direction: column;\n        }\n      }\n    </style>\n  </head>\n  <body>\n    <main class=\"shell\">\n      <section class=\"header\">\n        <div class=\"brand\">\n          <div class=\"eyebrow\">Application Error</div>\n          <h1>{{ errorName }}: {{ message }}</h1>\n          <p class=\"message\">The application hit an exception while rendering this request. The snippet below shows the active frame and the stack trace collected from the failing request.</p>\n        </div>\n      </section>\n\n      <section class=\"meta-grid\" aria-label=\"Request summary\">\n        <div class=\"meta\">\n          <span class=\"label\">Status</span>\n          <span class=\"value\">{{ statusCode }}</span>\n        </div>\n        <div class=\"meta\">\n          <span class=\"label\">Request</span>\n          <span class=\"value\">{{ req.method }} {{ req.url }}</span>\n        </div>\n        <div class=\"meta\">\n          <span class=\"label\">Route</span>\n          <span class=\"value\">{{ req.route }}</span>\n        </div>\n        <div class=\"meta\">\n          <span class=\"label\">Environment</span>\n          <span class=\"value\">{{ app.env }}{{ app.debug ? ' (debug)' : '' }}</span>\n        </div>\n      </section>\n\n      <section class=\"layout\">\n        <article class=\"panel\">\n          <div class=\"panel-head\">\n            <h2 class=\"panel-title\">Source</h2>\n            <span>{{ sourceFile }}</span>\n          </div>\n          <div class=\"panel-body\">\n            @if(sourceHtml)\n              <div class=\"code-frame\" aria-label=\"Source excerpt\">\n                {{{ sourceHtml }}} \n              </div>\n            @else\n              <div style=\"padding: 16px; color: #475569;\">No local source file could be resolved for the top stack frame.</div>\n            @endif\n          </div>\n        </article>\n\n        <aside class=\"panel\">\n          <div class=\"panel-head\">\n            <h2 class=\"panel-title\">Trace</h2>\n            <span>{{ traceCount }} frames</span>\n          </div>\n          <div class=\"trace-list\">\n            {{{ traceHtml }}}\n          </div>\n        </aside>\n      </section>\n\n      <details>\n        <summary>Stack trace</summary>\n        <pre>{{ stack }}</pre>\n      </details>\n\n      <p class=\"footer\">Request IP: {{ req.ip }} &middot; App: {{ app.name }}</p>\n    </main>\n  </body>\n</html>\n","dependencyFiles":[],"dependencyMtimes":{}}